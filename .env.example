# ─────────────────────────────────────────────────────────────
# VMP Villa — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Create a project at https://supabase.com, then run supabase/schema.sql
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Razorpay ──────────────────────────────────────────────────
# Test keys: https://dashboard.razorpay.com/app/keys
# Use rzp_test_* keys for development, rzp_live_* for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── WhatsApp / Business contact ───────────────────────────────
# The host WhatsApp number (without +, with country code)
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210
HOST_WHATSAPP=919876543210

# ── Email (SMTP) ──────────────────────────────────────────────
# Gmail: enable App Password at https://myaccount.google.com/apppasswords
# Brevo SMTP: smtp-relay.brevo.com, port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=VMP Villa <your-email@gmail.com>
HOST_EMAIL=hello@vmpvilla.in

# ── WhatsApp Business API (AiSensy) ───────────────────────────
# Get API key at https://app.aisensy.com → Settings → API Access
# Leave blank to skip WhatsApp notifications (email still works)
AISENSY_API_KEY=
